# Flask Configuration
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=your-secret-key-change-this

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/cybercafe_erp
SQLALCHEMY_ECHO=False

# Admin Panel
ADMIN_SECRET_KEY=admin-secret-key-change-this

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-password

# App Configuration
DEBUG=False
TESTING=False